OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
MOCK_LLM=false

# SQLite (local dev default)
DATABASE_URL=sqlite:///./support.db

# PostgreSQL (docker-compose up postgres)
# DATABASE_URL=postgresql://support:support@localhost:5432/support_agent
# Async driver auto: postgresql+asyncpg://...

# Auth: customer_id:api_key (tenant=default) or tenant:customer_id:api_key
# API_KEYS=cust_456:dev-key-456
# API_KEYS=default:cust_456:dev-key-456,acme:cust_acme:acme-key

# CORS: * or comma-separated origins
CORS_ORIGINS=*

# Langfuse (optional tracing)
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# Plugin tools (optional): plugins.example_promo
# PLUGIN_MODULE=plugins.example_promo

# Eval A/B prompt variant: a | b
# EVAL_PROMPT_VARIANT=a

# METRICS_ENABLED=true
# RAG_MODE=auto
# RAG_USE_MOCK_EMBEDDINGS=true
# EMBEDDING_MODEL=text-embedding-3-small
RATE_LIMIT_PER_MINUTE=60

# Cache (optional Redis; without Redis uses in-memory)
# REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300
SESSION_CACHE_TTL_SECONDS=3600

# Admin panel (/admin-ui/) — header X-Admin-Key
# ADMIN_API_KEY=your-admin-secret

# Staging profile (Postgres + Redis + auth): see .env.staging.example
ZENDESK_MOCK=true
# ZENDESK_SUBDOMAIN=your-subdomain
# ZENDESK_EMAIL=agent@company.com
# ZENDESK_API_TOKEN=your-token
