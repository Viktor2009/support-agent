# Staging profile — matches docker-compose.staging.yml
# Copy to .env for local staging parity or use compose env directly.

MOCK_LLM=true
DATABASE_URL=postgresql://support:support@localhost:5432/support_agent
REDIS_URL=redis://localhost:6379/0

API_KEYS=cust_456:staging-key-cust456
ADMIN_API_KEY=staging-admin-key
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
RATE_LIMIT_PER_MINUTE=60

METRICS_ENABLED=true
RAG_MODE=auto
RAG_USE_MOCK_EMBEDDINGS=true
ZENDESK_MOCK=true
