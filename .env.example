OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
MOCK_LLM=false

# SQLite (local dev default)
DATABASE_URL=sqlite:///./support.db

# PostgreSQL (docker-compose up postgres)
# DATABASE_URL=postgresql://support:support@localhost:5432/support_agent

# Auth: customer_id:api_key pairs (comma-separated). Empty = auth disabled.
# API_KEYS=cust_456:dev-key-456,cust_789:dev-key-789

# CORS: * or comma-separated origins
CORS_ORIGINS=*

# Langfuse (optional tracing)
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com
