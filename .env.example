OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
MOCK_LLM=false

# SQLite (local dev default)
DATABASE_URL=sqlite:///./support.db

# PostgreSQL (docker-compose up postgres)
# DATABASE_URL=postgresql://support:support@localhost:5432/support_agent

# Auth: customer_id:api_key pairs (comma-separated). Empty = auth disabled.
# API_KEYS=cust_456:dev-key-456,cust_789:dev-key-789

# CORS: * or comma-separated origins
CORS_ORIGINS=*

# Langfuse (optional tracing)
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# Rate limiting (requests/minute per IP, 0 = off)
RATE_LIMIT_PER_MINUTE=60

# Cache (optional Redis; without Redis uses in-memory)
# REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300

# Admin panel (/admin/) — header X-Admin-Key
# ADMIN_API_KEY=your-admin-secret
ZENDESK_MOCK=true
# ZENDESK_SUBDOMAIN=your-subdomain
# ZENDESK_EMAIL=agent@company.com
# ZENDESK_API_TOKEN=your-token
